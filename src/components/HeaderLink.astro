---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href = '', class: className, ...props } = Astro.props;

const baseRaw = import.meta.env.BASE_URL;
const base =
	baseRaw === '/'
		? ''
		: baseRaw.endsWith('/')
			? baseRaw.slice(0, -1)
			: baseRaw;
const addBase = (target: string) => {
	if (!target || target.startsWith('http') || target.startsWith('mailto:') || target.startsWith('#')) {
		return target;
	}
	const normalised = target.startsWith('/') ? target.slice(1) : target;
	return `${base}/${normalised}`;
};

const resolvedHref = addBase(href);

const normalisePath = (path: string) =>
	path === '/' ? '' : path.replace(import.meta.env.BASE_URL, '').replace(/^\/|\/$/g, '');

const currentPath = normalisePath(Astro.url.pathname);
const targetPath = normalisePath(href);
const isActive =
	targetPath === ''
		? currentPath === ''
		: currentPath === targetPath || currentPath.startsWith(`${targetPath}/`);
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
		color: inherit;
		border-radius: 999px;
		transition: background 180ms ease, color 180ms ease, box-shadow 180ms ease;
	}
	a.active {
		font-weight: 700;
		background: rgba(0, 0, 0, 0.08);
		color: #111;
	}
	a:hover {
		background: rgba(0, 0, 0, 0.06);
	}
	a:focus-visible {
		outline: 2px solid rgba(156, 163, 175, 0.72);
		outline-offset: 3px;
	}
</style>
