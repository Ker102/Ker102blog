---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'Case Studies & Project Evidence - Kristofer Jussmann';
const description =
	'Structured project evidence and case studies for PromptTriage, Kaelux.dev, ViperMesh, and n8n automation work.';

const evidenceCards = [
	{
		name: 'Kaelux.dev',
		status: 'Source verified',
		type: 'AI engineering agency platform',
		summary:
			'Brand and platform site for AI engineering services, featuring a diagnostic agent, technical wiki, featured project hub, SEO/GEO content, and deployment documentation.',
		stack: ['Next.js', 'React', 'TypeScript', 'Tailwind CSS', 'Vercel AI SDK', 'Groq', 'DigitalOcean'],
		links: [
			{ label: 'Live site', href: 'https://kaelux.dev' },
			{ label: 'Repository', href: 'https://github.com/Ker102/Kaelux-DevPortfolio' },
		],
	},
	{
		name: 'ViperMesh',
		status: 'Case study in progress',
		type: 'AI-powered Blender assistant and neural 3D workflow product',
		summary:
			'Renamed from the older ModelForge identity. Local evidence describes an Electron and Blender Python platform with a ViperAgent workflow, RAG-backed generation, addon awareness, and neural 3D service planning.',
		stack: ['Electron', 'Blender Python API', 'LangChain', 'LangGraph', 'Supabase', 'Docker'],
		links: [
			{ label: 'Repository', href: 'https://github.com/Ker102/ViperMesh' },
		],
	},
	{
		name: 'n8n Automation Atlas',
		status: 'Source verified',
		type: 'Workflow library, explorer, and automation evidence base',
		summary:
			'Curated workflow library with ready-to-import n8n JSON exports, source license preservation, and an explorer path for builders who need practical automation templates.',
		stack: ['n8n', 'JSON', 'Vue', 'Vite', 'GitHub Pages'],
		links: [
			{ label: 'Atlas repository', href: 'https://github.com/Ker102/n8n-ai-automation-workflow-atlas' },
			{ label: 'n8n workflows repo', href: 'https://github.com/Ker102/n8n-workflows-36k' },
		],
	},
];

const templateSections = [
	{
		title: 'Executive summary',
		body:
			'PromptTriage is a RAG-powered prompt engineering platform built to turn rough ideas into production-ready prompts across text, image, video, and system-prompt workflows. It combines a Next.js interface, FastAPI retrieval services, Pinecone vector search, modality-specific metaprompts, and research from a 28K+ prompt corpus. The strongest evidence is not only the app surface, but the documented research process behind retrieval strategy, prompt format, model selection, evaluation bias, and cost tradeoffs.',
	},
	{
		title: 'Problem',
		body:
			'Most prompt tools behave like thin wrappers over a model API. The project needed to show whether structured prompt generation, retrieval context, and modality-specific templates could produce better, more reliable prompts than generic chat UX. The user problem is practical: builders need reusable prompts that include constraints, output format, assumptions, and evaluation criteria without manually writing every section from scratch.',
	},
	{
		title: 'Context and constraints',
		body:
			'The project was developed as a solo engineering effort with limited budget, evolving model availability, provider API instability, and a need to publish evidence without exposing secrets or private datasets. Research notes show cost-sensitive experimentation across fine-tuned Qwen variants, RAG strategies, and LLM-as-judge workflows. The implementation had to support public demo value while keeping API keys, auth configuration, and vector infrastructure outside the repository.',
	},
	{
		title: 'Requirements',
		body:
			'Functional requirements included prompt analysis, dynamic clarification questions, modality routing, retrieval from a prompt corpus, final prompt synthesis, one-click iteration, and optional current-documentation lookup through MCP tooling. Non-functional requirements included secure authentication, environment-based secrets, responsive UI, reproducible prompt versions, structured logging, and a path toward fine-tuning or API access.',
	},
	{
		title: 'Architecture',
		body:
			'The architecture separates the user-facing workflow from retrieval and prompt-engineering services. The UI collects intent and modality, API routes orchestrate analysis/refinement, the backend retrieves relevant examples from Pinecone, and modality-specific metaprompts synthesize the final result. The design keeps RAG context as supporting evidence rather than letting retrieval traces dominate the final answer.',
	},
	{
		title: 'Security model',
		body:
			'Security evidence in the repository emphasizes Google OAuth, NextAuth session handling, environment-based configuration, and responsible disclosure documentation. The current public case study should present the security model as an application-level control set: authenticated access, secrets outside source control, external API keys in environment variables, and no publication of private credentials or indexes.',
	},
	{
		title: 'Deployment pipeline',
		body:
			'The local documentation includes a GCP Cloud Run deployment guide and separates frontend, backend, and retrieval concerns. A mature deployment path is: local validation, GitHub commit, frontend build, backend service deployment, environment configuration, vector database availability checks, and post-deploy smoke testing of analyze/refine flows.',
	},
	{
		title: 'Operations',
		body:
			'Operational evidence includes pipeline logging, error feedback UX, dataset ingestion scripts, research progress notes, and failure tracking around model/provider behavior. The next operational step is to formalize runbooks, monitoring thresholds, incident response, and rollback paths so the project evidence matches the documentation standard.',
	},
	{
		title: 'Cost analysis',
		body:
			'Research notes include explicit cost tracking: Study A was estimated around $5.50, Study B around $188, later re-judging and format studies were lower-cost API runs, and the MoE benchmark showed how quickly naive inference can become expensive. The important lesson is that evaluation design and runtime choice matter as much as raw model size.',
	},
	{
		title: 'Results',
		body:
			'Documented results include a 28K+ prompt evidence base, Pinecone retrieval, multiple completed studies, qwen3_14b selected as a production candidate in the research notes, and a finding that naive RAG performed better than more complex RAG variants for this pipeline. Some downstream benchmark results were nuanced, so the case study should preserve both positive findings and null results instead of overstating uniform gains.',
	},
	{
		title: 'Tradeoffs',
		body:
			'The main tradeoff was simplicity versus orchestration complexity. Naive RAG was easier to operate and outperformed more agentic retrieval variants in the documented study, while complex corrective or judge-based RAG added noise. The project also trades broad provider coverage for a more controlled, research-backed prompt workflow.',
	},
	{
		title: 'Failure modes and lessons learned',
		body:
			'The research logs are valuable because they document failures: judge bias, provider/model availability issues, expensive slow MoE inference, overfitting on small datasets, and prompt strategies that did not move downstream scores. These failures make the project stronger as engineering evidence because they show measurement discipline rather than only demo polish.',
	},
	{
		title: 'What I would improve next',
		body:
			'Next improvements should include a formal runbook, security model page, threat model, cost report, architecture diagram stored in the repo, API rate limiting, clearer public benchmark reports, and a more complete deployment checklist. Those additions align directly with the documentation standard from the career execution pack.',
	},
	{
		title: 'Repository and demo links',
		body:
			'The public demo is hosted at prompttriage.kaelux.dev and the repository is available on GitHub. The strongest supporting evidence is the README, backend research notes, deployment guide, contributing guide, security policy, and dataset documentation.',
	},
	{
		title: 'Interview explanation',
		body:
			'I built PromptTriage because prompt quality is usually treated as subjective, but production AI systems need measurable prompt structure, retrieval context, and evaluation discipline. The architecture uses a Next.js interface, API orchestration, FastAPI retrieval, Pinecone vectors, and modality-specific metaprompts. The most important lesson was that more complex RAG is not automatically better: in this project, simple retrieval produced stronger documented results than agentic retrieval traces.',
	},
	{
		title: 'Resume bullets',
		body:
			'Designed a RAG-powered prompt engineering platform with modality-specific optimization, Pinecone retrieval, and documented evaluation studies. Built and evaluated prompt-generation workflows across model selection, retrieval strategy, judge bias, and format sensitivity. Documented cost, failure modes, and tradeoffs to make the project inspectable by engineering reviewers.',
	},
];

const futureStudies = [
	'Kaelux.dev platform case study with service architecture, diagnostic agent, deployment, observability, and GEO/wiki strategy.',
	'ViperMesh case study with Blender integration, agent tool model, neural 3D workflow, and local-to-cloud deployment choices.',
	'n8n workflow dataset and automation atlas case study with curation pipeline, licensing, import UX, and downstream model-training path.',
	'Homelab, Azure, and security lab case studies once the repo documentation standard is applied.',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			body {
				background:
					radial-gradient(circle at 12% 8%, rgba(0, 113, 227, 0.10), transparent 34rem),
					radial-gradient(circle at 92% 18%, rgba(26, 188, 156, 0.10), transparent 30rem),
					#f5f5f7;
				color: #1d1d1f;
			}

			main.case-study-page {
				width: min(100%, 1180px);
				max-width: none;
				padding: 7.5rem 1rem 7rem;
			}

			.eyebrow {
				display: inline-flex;
				align-items: center;
				width: fit-content;
				padding: 0.35rem 0.7rem;
				border: 1px solid rgba(0, 0, 0, 0.08);
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.72);
				color: #3b4655;
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.hero {
				display: grid;
				gap: 1.25rem;
				padding-bottom: 2.5rem;
			}

			.hero h1 {
				max-width: 820px;
				margin: 0;
				font-size: clamp(2.45rem, 12vw, 5.25rem);
				line-height: 0.98;
				letter-spacing: 0;
				background: linear-gradient(180deg, #050505 0%, #7a7f88 100%);
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
			}

			.hero p {
				max-width: 760px;
				margin: 0;
				color: #5c6470;
				font-size: clamp(1rem, 4.4vw, 1.25rem);
				line-height: 1.65;
			}

			.hero-actions,
			.card-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 44px;
				padding: 0.75rem 1rem;
				border-radius: 999px;
				border: 1px solid rgba(0, 0, 0, 0.1);
				font-weight: 700;
				font-size: 0.95rem;
				text-decoration: none;
				transition:
					transform 220ms var(--ease-apple),
					border-color 220ms var(--ease-apple),
					background 220ms var(--ease-apple),
					box-shadow 220ms var(--ease-apple);
			}

			.button.primary {
				background: #101010;
				color: #fff;
				box-shadow: 0 14px 32px rgba(0, 0, 0, 0.16);
			}

			.button.secondary {
				background: rgba(255, 255, 255, 0.72);
				color: #111;
			}

			.button:hover,
			.button:focus-visible {
				transform: translateY(-2px);
				border-color: rgba(0, 0, 0, 0.22);
				box-shadow: 0 18px 36px rgba(0, 0, 0, 0.14);
			}

			.trust-strip {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.75rem;
				margin: 0 0 1.5rem;
			}

			.trust-item,
			.project-card,
			.featured,
			.section-card,
			.pipeline,
			.cta-panel {
				border: 1px solid rgba(255, 255, 255, 0.72);
				background: rgba(255, 255, 255, 0.68);
				box-shadow: 0 18px 50px rgba(30, 41, 59, 0.08);
				backdrop-filter: blur(28px);
				-webkit-backdrop-filter: blur(28px);
			}

			.trust-item {
				padding: 1rem;
				border-radius: 22px;
			}

			.trust-item strong {
				display: block;
				font-size: 1rem;
				color: #111;
			}

			.trust-item span {
				display: block;
				margin-top: 0.25rem;
				color: #657080;
				font-size: 0.9rem;
			}

			.section-heading {
				display: grid;
				gap: 0.4rem;
				margin: 3rem 0 1rem;
			}

			.section-heading h2 {
				margin: 0;
				font-size: clamp(1.8rem, 8vw, 3rem);
				line-height: 1.08;
				letter-spacing: 0;
			}

			.section-heading p {
				max-width: 760px;
				margin: 0;
				color: #636b76;
				line-height: 1.6;
			}

			.featured {
				position: relative;
				overflow: hidden;
				border-radius: 30px;
				padding: clamp(1.1rem, 5vw, 2.5rem);
			}

			.featured::before {
				content: '';
				position: absolute;
				inset: 0;
				pointer-events: none;
				background: linear-gradient(135deg, rgba(0, 113, 227, 0.13), transparent 42%);
			}

			.featured > * {
				position: relative;
			}

			.featured-header {
				display: grid;
				gap: 1rem;
				margin-bottom: 1.5rem;
			}

			.status {
				display: inline-flex;
				width: fit-content;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(0, 113, 227, 0.1);
				color: #0057b8;
				font-size: 0.78rem;
				font-weight: 800;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.featured h2,
			.featured h3,
			.project-card h3 {
				margin: 0;
				letter-spacing: 0;
			}

			.featured h2 {
				font-size: clamp(2rem, 9vw, 4rem);
				line-height: 1;
			}

			.featured-summary {
				margin: 0;
				color: #505966;
				font-size: clamp(1rem, 4vw, 1.15rem);
				line-height: 1.65;
			}

			.metric-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.8rem;
				margin: 1.5rem 0;
			}

			.metric {
				padding: 1rem;
				border-radius: 20px;
				background: rgba(255, 255, 255, 0.66);
				border: 1px solid rgba(0, 0, 0, 0.06);
			}

			.metric strong {
				display: block;
				color: #111;
				font-size: 1.55rem;
				line-height: 1;
			}

			.metric span {
				display: block;
				margin-top: 0.35rem;
				color: #657080;
				font-size: 0.88rem;
				line-height: 1.35;
			}

			.architecture-map {
				display: grid;
				gap: 0.75rem;
				margin: 1.5rem 0;
			}

			.node {
				padding: 0.9rem 1rem;
				border-radius: 18px;
				background: #101010;
				color: #fff;
				font-weight: 700;
				text-align: center;
			}

			.node.light {
				background: rgba(255, 255, 255, 0.86);
				color: #111;
				border: 1px solid rgba(0, 0, 0, 0.08);
			}

			.template-grid,
			.project-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.9rem;
			}

			.section-card,
			.project-card,
			.pipeline,
			.cta-panel {
				border-radius: 24px;
				padding: 1rem;
			}

			.section-card h3 {
				font-size: 1.05rem;
				margin: 0 0 0.55rem;
			}

			.section-card p,
			.project-card p,
			.pipeline li,
			.cta-panel p {
				margin: 0;
				color: #5c6470;
				line-height: 1.6;
			}

			.project-card {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				transition:
					transform 220ms var(--ease-apple),
					box-shadow 220ms var(--ease-apple),
					background 220ms var(--ease-apple);
			}

			.project-card:hover {
				transform: translateY(-4px);
				background: rgba(255, 255, 255, 0.84);
				box-shadow: 0 22px 56px rgba(30, 41, 59, 0.12);
			}

			.project-meta {
				color: #657080;
				font-size: 0.9rem;
				font-weight: 700;
			}

			.stack-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
			}

			.stack-list span {
				padding: 0.32rem 0.6rem;
				border-radius: 999px;
				background: rgba(0, 0, 0, 0.06);
				color: #2f3844;
				font-size: 0.78rem;
				font-weight: 700;
			}

			.text-link {
				display: inline-flex;
				align-items: center;
				min-height: 36px;
				color: #0066cc;
				font-weight: 800;
				text-decoration: none;
			}

			.text-link:hover,
			.text-link:focus-visible {
				text-decoration: underline;
				text-underline-offset: 4px;
			}

			.pipeline ul {
				display: grid;
				gap: 0.75rem;
				padding: 0;
				margin: 0;
			}

			.pipeline li {
				padding-left: 1rem;
				border-left: 3px solid rgba(0, 113, 227, 0.28);
			}

			.cta-panel {
				display: grid;
				gap: 1rem;
				margin-top: 3rem;
				background: #101010;
				color: #fff;
			}

			.cta-panel h2 {
				margin: 0;
				color: #fff;
				letter-spacing: 0;
			}

			.cta-panel p {
				color: rgba(255, 255, 255, 0.74);
			}

			.cta-panel .button.secondary {
				background: rgba(255, 255, 255, 0.1);
				color: #fff;
				border-color: rgba(255, 255, 255, 0.18);
			}

			@media (min-width: 640px) {
				main.case-study-page {
					padding-inline: 1.5rem;
				}

				.trust-strip,
				.metric-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.architecture-map {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (min-width: 900px) {
				main.case-study-page {
					padding-top: 9rem;
				}

				.hero {
					gap: 1.5rem;
					padding-bottom: 3rem;
				}

				.trust-strip {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}

				.featured-header {
					grid-template-columns: minmax(0, 1fr) 320px;
					align-items: end;
				}

				.metric-grid,
				.project-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.template-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.cta-panel {
					grid-template-columns: minmax(0, 1fr) auto;
					align-items: center;
					padding: 2rem;
				}
			}

			@media (min-width: 1100px) {
				.template-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					transition-duration: 0.01ms !important;
					animation-duration: 0.01ms !important;
					animation-iteration-count: 1 !important;
				}

				.button:hover,
				.button:focus-visible,
				.project-card:hover {
					transform: none;
				}
			}
		</style>
	</head>
	<body data-theme="clean">
		<Header />
		<main class="case-study-page">
			<section class="hero">
				<span class="eyebrow">Project evidence for reviewers</span>
				<h1>Case Studies & Project Evidence</h1>
				<p>
					A hiring-manager friendly map of what I have built, what is fully documented,
					and what is still being turned into structured case studies.
				</p>
				<div class="hero-actions">
					<a class="button primary" href="#prompttriage">Read PromptTriage</a>
					<a class="button secondary" href="#project-evidence">Browse projects</a>
				</div>
			</section>

			<section class="trust-strip" aria-label="Evidence categories">
				<div class="trust-item">
					<strong>Systems</strong>
					<span>Working software, demos, and repositories.</span>
				</div>
				<div class="trust-item">
					<strong>Research</strong>
					<span>Benchmarks, evaluation notes, and costs.</span>
				</div>
				<div class="trust-item">
					<strong>Operations</strong>
					<span>Deployment, logging, runbooks, and failure modes.</span>
				</div>
				<div class="trust-item">
					<strong>Hiring signal</strong>
					<span>Fast summaries with links to deeper evidence.</span>
				</div>
			</section>

			<section id="prompttriage" class="featured">
				<div class="featured-header">
					<div>
						<span class="status">Complete case study</span>
						<h2>PromptTriage</h2>
						<p class="featured-summary">
							RAG-powered prompt engineering platform with a documented research trail,
							modality-specific optimization, and a public demo.
						</p>
					</div>
					<div class="card-actions">
						<a class="button primary" href="https://prompttriage.kaelux.dev" target="_blank" rel="noopener noreferrer">Live demo</a>
						<a class="button secondary" href="https://github.com/Ker102/PromptTriage" target="_blank" rel="noopener noreferrer">Repository</a>
					</div>
				</div>

				<div class="metric-grid" aria-label="PromptTriage evidence metrics">
					<div class="metric">
						<strong>28K+</strong>
						<span>Prompt corpus referenced in local project evidence.</span>
					</div>
					<div class="metric">
						<strong>4</strong>
						<span>Prompt modalities: text, image, video, and system prompts.</span>
					</div>
					<div class="metric">
						<strong>L1</strong>
						<span>Naive RAG was the strongest documented retrieval strategy.</span>
					</div>
					<div class="metric">
						<strong>5+</strong>
						<span>Completed research studies covering model, RAG, format, and judge behavior.</span>
					</div>
				</div>

				<div class="architecture-map" aria-label="PromptTriage architecture diagram">
					<div class="node">User intent and modality</div>
					<div class="node light">Next.js interface and API routes</div>
					<div class="node light">FastAPI RAG service</div>
					<div class="node">Pinecone prompt corpus</div>
					<div class="node light">Modality-specific metaprompts</div>
					<div class="node">Production-ready prompt output</div>
				</div>

				<div class="template-grid">
					{templateSections.map((section) => (
						<article class="section-card">
							<h3>{section.title}</h3>
							<p>{section.body}</p>
						</article>
					))}
				</div>
			</section>

			<section id="project-evidence">
				<div class="section-heading">
					<span class="eyebrow">Project evidence cards</span>
					<h2>Verified work that will become full case studies</h2>
					<p>
						These projects have enough local or public evidence to be useful to reviewers,
						but they are not labeled as complete case studies until each template section
						has been documented.
					</p>
				</div>

				<div class="project-grid">
					{evidenceCards.map((project) => (
						<article class="project-card">
							<span class="status">{project.status}</span>
							<div>
								<h3>{project.name}</h3>
								<div class="project-meta">{project.type}</div>
							</div>
							<p>{project.summary}</p>
							<div class="stack-list" aria-label={`${project.name} stack`}>
								{project.stack.map((item) => <span>{item}</span>)}
							</div>
							<div class="card-actions">
								{project.links.map((link) => (
									<a class="text-link" href={link.href} target="_blank" rel="noopener noreferrer">
										{link.label} &rarr;
									</a>
								))}
							</div>
						</article>
					))}
				</div>
			</section>

